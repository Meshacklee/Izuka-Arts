rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /artworks/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        request.auth.token.email == "fastinsms.com@gmail.com";
    }
    match /thumbnails/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        request.auth.token.email == "fastinsms.com@gmail.com";
    }
  }
}
